%https://tex.stackexchange.com/questions/22278/palatino-roman-chi-and-the-math-mode/22285#22285
\DeclareRobustCommand\ve[1]{{%
  \ifcat\noexpand#1\relax
    \expandafter\boldsymbol
  \else
    \expandafter\mathbf
\fi{#1}}}

\newcommand{\ma}[1]{\ve{#1}}

\DeclareMathAlphabet\mathbfcal{OMS}{cmsy}{b}{n}
\newcommand{\op}[1]{\mathbfcal{#1}}
\newcommand{\hop}[1]{\hve{\mathcal{#1}}}
% versions of the above with hats 
\newcommand{\hve}[1]{{\widehat{\ve{#1}}}}
\newcommand{\hma}[1]{{\hve{#1}}}
% versions with tildes
\newcommand{\tve}[1]{\widetilde{\ve{#1}}}
\newcommand{\tma}[1]{\tve{#1}}
% versions with checks
\newcommand{\cve}[1]{{\widecheck{\ve{#1}}}}
\newcommand{\cma}[1]{{\cve{#1}}}
% versions with dots
\newcommand{\dve}[1]{{\dot{\ve{#1}}}}
\newcommand{\dma}[1]{{\dve{#1}}}
% versions with underlines 
\newcommand{\uve}[1]{{\underline{\ve{#1}}}}
\newcommand{\uma}[1]{{\uve{#1}}}
% versions with overlines 
\newcommand{\ove}[1]{{\overline{\ve{#1}}}}
\newcommand{\oma}[1]{{\ove{#1}}}
% versions with underlines and tildes
\newcommand{\tuve}[1]{{\tilde{\uve{#1}}}}
\newcommand{\tuma}[1]{{\tuve{#1}}}
% versions with underlines and hats
\newcommand{\huve}[1]{{\hat{\uve{#1}}}}
\newcommand{\huma}[1]{{\huve{#1}}}
% versions with overlines and tildes
\newcommand{\tove}[1]{{\tilde{\ove{#1}}}}
\newcommand{\toma}[1]{{\tove{#1}}}
% versions with vectors 
% https://tex.stackexchange.com/a/192517/
\newcommand{\harp}[1]{\mathpalette\harpoonvec{#1}}
\newcommand{\harpvecsign}{\scriptstyle\rightharpoonup}
\newcommand{\harpoonvec}[2]{%
  \ifx\displaystyle#1\doalign{$\harpvecsign$}{#1#2}\fi
  \ifx\textstyle#1\doalign{$\harpvecsign$}{#1#2}\fi
  \ifx\scriptstyle#1\doalign{\scalebox{.6}[.9]{$\harpvecsign$}}{#1#2}\fi
  \ifx\scriptscriptstyle#1\doalign{\scalebox{.5}[.8]{$\harpvecsign$}}{#1#2}\fi
}
\newcommand{\doalign}[2]{%
 {\vbox{\offinterlineskip\ialign{\hfil##\hfil\cr#1\cr$#2$\cr}}}%
}

\newcommand{\vve}[1]{\harp{\ve{#1}}}
\newcommand{\vma}[1]{\harp{\ma{#1}}}
